  <para style="p"> <verse style="v" number="23" /><char style="wj"><char style="rb" gloss="Οὐαὶ">Woe</char> <char style="rb" gloss="ὑμῖν">to you</char>, <char style="rb" gloss="γραμματεῖς">scribes</char> <char style="rb" gloss="καὶ">and</char> <char style="rb" gloss="Φαρισαῖοι">Pharisees</char>, <char style="rb" gloss="ὑποκριταί">you hypocrites</char>!<char style="rb" gloss="ὅτι" /> <char style="rb" gloss="ἀποδεκατοῦτε">You pay tithes of</char><char style="rb" gloss="τὸ" /> <char style="rb" gloss="ἡδύοσμον">mint</char>,<char style="rb" gloss="καὶ" /><char style="rb" gloss="τὸ" /> <char style="rb" gloss="ἄνηθον">dill</char>, <char style="rb" gloss="καὶ">and</char><char style="rb" gloss="τὸ" /> <char style="rb" gloss="κύμινον">cumin</char>. <char style="rb" gloss="καὶ">But</char> <char style="rb" gloss="ἀφήκατε">you have disregarded</char> <char style="rb" gloss="τὰ">the</char> <char style="rb" gloss="βαρύτερα">weightier matters</char> <char style="rb" gloss="τοῦ">of the</char> <char style="rb" gloss="νόμου">law</char>:<char style="rb" gloss="τὴν" /> <char style="rb" gloss="κρίσιν">justice</char>,<char style="rb" gloss="καὶ" /><char style="rb" gloss="τὸν" /> <char style="rb" gloss="ἔλεον">mercy</char>, <char style="rb" gloss="καὶ">and</char><char style="rb" gloss="τὴν" /> <char style="rb" gloss="πίστιν">faithfulness</char>. <char style="rb" gloss="ἔδει">You should have</char> <char style="rb" gloss="ποιῆσαι">practiced</char> <char style="rb" gloss="ταῦτα">the latter</char>, <char style="rb" gloss="μὴ">without</char> <char style="rb" gloss="ἀφιέναι">neglecting</char> <char style="rb" gloss="κἀκεῖνα">the former</char>.<char style="rb" gloss="" /><char style="rb" gloss="" /><char style="rb" gloss="" /><char style="rb" gloss="" /><char style="rb" gloss="" /><char style="rb" gloss="" /><char style="rb" gloss="" /><char style="rb" gloss="" /><char style="rb" gloss="" /><char style="rb" gloss="" /> <verse style="v" number="24" /><char style="rb" gloss="τυφλοί">You blind</cha